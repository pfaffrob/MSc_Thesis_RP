@article{chockglobalthreat2020,
  title = {The Global Threat of {{Myrtle}} Rust ({{{\emph{Austropuccinia}}}}{\emph{ Psidii}}): {{Future}} Prospects for Control and Breeding Resistance in Susceptible Hosts},
  shorttitle = {The Global Threat of {{Myrtle}} Rust ({{AUSTROPUCCINIA}} Psidii)},
  author = {Chock, M.K.},
  year = 2020,
