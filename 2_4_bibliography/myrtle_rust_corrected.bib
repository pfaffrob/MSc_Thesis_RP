@article{toome-hellerChasingmyrtle2020,
  title = {Chasing Myrtle Rust in {{New Zealand}}: Host Range and Distribution over the First Year after Invasion},
  shorttitle = {Chasing Myrtle Rust in {{New Zealand}}},
  author = {{Toome-Heller}, M. and Ho, W. W. H. and Ganley, R. J. and Elliott, C. E. A. and Quinn, B. and Pearson, H. G. and Alexander, B. J. R.},
  year = 2020,
  month = may,
  journal = {Australasian Plant Pathology},
