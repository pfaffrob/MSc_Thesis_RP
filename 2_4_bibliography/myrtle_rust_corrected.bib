@article{blackHowIndigenousCommunity2019,
  title = {How an {{Indigenous}} Community Responded to the Incursion and Spread of Myrtle Rust ({{Austropuccinia}} Psidii) That Threatens Culturally Significant Plant Species -- a Case Study from {{New Zealand}}},
  author = {Black, Amanda and {Mark-Shadbolt}, Melanie and Garner, Gary and Green, Jenny and Malcolm, Tame and Marsh, Alby and Ropata, Hone and Waipara, Nick and Wood, Waitangi},
  year = 2019,
