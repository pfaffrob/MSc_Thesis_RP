@article{seebensProjectingcontinental2021,
  title = {Projecting the Continental Accumulation of Alien Species through to 2050},
  author = {Seebens, Hanno and Bacher, Sven and Blackburn, Tim M. and Capinha, C{\'e}sar and Dawson, Wayne and Dullinger, Stefan and Genovesi, Piero and Hulme, Philip E. and Van Kleunen, Mark and K{\"u}hn, Ingolf and Jeschke, Jonathan M. and Lenzner, Bernd and Liebhold, Andrew M. and Pattison, Zarah and Pergl, Jan and Py{\v s}ek, Petr and Winter, Marten and Essl, Franz},
  year = 2021,
  month = mar,
  journal = {Global Change Biology},
  volume = {27},
  number = {5},
  pages = {970--982},
  issn = {1354-1013, 1365-2486},
  doi = {10.1111/gcb.15333},
  url = {https://onlinelibrary.wiley.com/doi/10.1111/gcb.15333},
  urldate = {2025-09-10},
  abstract = {Abstract             Biological invasions have steadily increased over recent centuries. However, we still lack a clear expectation about future trends in alien species numbers. In particular, we do not know whether alien species will continue to accumulate in regional floras and faunas, or whether the pace of accumulation will decrease due to the depletion of native source pools. Here, we apply a new model to simulate future numbers of alien species based on estimated sizes of source pools and dynamics of historical invasions, assuming a continuation of processes in the future as observed in the past (a business-as-usual scenario). We first validated performance of different model versions by conducting a back-casting approach, therefore fitting the model to alien species numbers until 1950 and validating predictions on trends from 1950 to 2005. In a second step, we selected the best performing model that provided the most robust predictions to project trajectories of alien species numbers until 2050. Altogether, this resulted in 3,790 stochastic simulation runs for 38 taxon--continent combinations. We provide the first quantitative projections of future trajectories of alien species numbers for seven major taxonomic groups in eight continents, accounting for variation in sampling intensity and uncertainty in projections. Overall, established alien species numbers per continent were predicted to increase from 2005 to 2050 by 36\%. Particularly, strong increases were projected for Europe in absolute (+2,543~\textpm ~237 alien species) and relative terms, followed by Temperate Asia (+1,597~\textpm ~197), Northern America (1,484~\textpm ~74) and Southern America (1,391~\textpm ~258). Among individual taxonomic groups, especially strong increases were projected for invertebrates globally. Declining (but still positive) rates were projected only for Australasia. Our projections provide a first baseline for the assessment of future developments of biological invasions, which will help to inform policies to contain the spread of alien species.},
  langid = {english},
  file = {/Users/robinpfaff/Zotero/storage/47FVXLRB/Seebens et al. - 2021 - Projecting the continental accumulation of alien species through to 2050.pdf}
}

@article{shahiDeepLearningBased2023,
  title = {Deep {{Learning-Based Weed Detection Using UAV Images}}: {{A Comparative Study}}},
  shorttitle = {Deep {{Learning-Based Weed Detection Using UAV Images}}},
  author = {Shahi, Tej Bahadur and Dahal, Sweekar and Sitaula, Chiranjibi and Neupane, Arjun and Guo, William},
  year = 2023,
  month = oct,
  journal = {Drones},
  volume = {7},
