@article{lobotorresApplyingFully2020,
  title = {Applying {{Fully Convolutional Architectures}} for {{Semantic Segmentation}} of a {{Single Tree Species}} in {{Urban Environment}} on {{High Resolution UAV Optical Imagery}}},
